//index.html

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Webpage</title>

    <!-- CSS File -->
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <header>
        <h1>Welcome to My Webpage</h1>
        <p>Basics of HTML, CSS and JavaScript</p>
    </header>

    <section class="content">

        <h2>About Web Development</h2>

        <p>
            Web development is the process of creating websites using
            HTML, CSS, and JavaScript.
        </p>

        <img src="fullstack.jpg"
             alt="Sample Image">

        <br><br>

        <a href="https://www.google.com" target="_blank">
            Visit Google
        </a>

        <br><br>

        <button onclick="showMessage()">
            Click Me
        </button>

    </section>

    <!-- JavaScript File -->
    <script src="script.js"></script>



//style.css

body {
    font-family: Arial, sans-serif;
    background-color: #f0f8ff;
    margin: 0;
    padding: 0;
    text-align: center;
}

header {
    background-color: #0077b6;
    color: white;
    padding: 20px;
}

.content {
    margin-top: 30px;
}

h2 {
    color: #023e8a;
}

p {
    font-size: 18px;
    color: #333;
    width: 70%;
    margin: auto;
    line-height: 1.6;
}

img {
    margin-top: 20px;
    width: 400px;
    border-radius: 10px;
}

a {
    text-decoration: none;
    color: #0077b6;
    font-weight: bold;
}

button {
    margin-top: 20px;
    padding: 12px 25px;
    background-color: #0096c7;
    color: white;
    border: none;
    border-radius: 5px;
    font-size: 16px;
    cursor: pointer;
}

button:hover {
    background-color: #023e8a;
}


//script.js

function showMessage() {
    alert("Hello! JavaScript Button Clicked Successfully.");
}

</body>
</html>
